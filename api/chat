// api/chat.js — Vercel Edge Function
// Edge runtime 跑在 Cloudflare 網路上,可以呼叫 Groq(也在 Cloudflare)
// 不像 Python/Node.js serverless 跑在 AWS Lambda,不會被 Cloudflare WAF 1010 擋
export const config = { runtime: 'edge' };

const DEFAULT_SYS = 'You are DOT, a concise and helpful AI assistant.';

export default async function handler(request) {
  if (request.method === 'GET') {
    return Response.json({
      runtime: 'edge',
      has_groq: !!process.env.GROQ_API_KEY,
      model: process.env.GROQ_MODEL || 'llama-3.1-8b-instant'
    });
  }

  if (request.method !== 'POST') {
    return new Response('method not allowed', { status: 405 });
  }

  const GROQ_KEY   = process.env.GROQ_API_KEY;
  const GROQ_MODEL = process.env.GROQ_MODEL || 'llama-3.1-8b-instant';

  if (!GROQ_KEY) {
    return Response.json({ reply: '⚠️ GROQ_API_KEY 未設定，請在 Vercel 環境變數加入。' });
  }

  let body;
  try { body = await request.json(); }
  catch(e) { return Response.json({ error: 'invalid JSON' }, { status: 400 }); }

  const messages = body.messages || [];
  const system   = body.system   || DEFAULT_SYS;

  try {
    const gr = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${GROQ_KEY}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model: GROQ_MODEL,
        messages: [{ role: 'system', content: system }, ...messages],
        max_tokens: 512,
        temperature: 0.7
      })
    });

    const text = await gr.text();
    let data;
    try { data = JSON.parse(text); }
    catch(e) { return Response.json({ reply: `⚠️ Groq 回傳非 JSON (${gr.status}): ${text.slice(0,200)}` }); }

    if (!data.choices) {
      return Response.json({ reply: `⚠️ Groq: ${JSON.stringify(data).slice(0,200)}` });
    }
    return Response.json({ reply: data.choices[0].message.content });

  } catch(e) {
    return Response.json({ reply: `⚠️ fetch error: ${e.message}` });
  }
}
