{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "api/chat.js",  "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/evolve", "schedule": "0 3 * * *" }
  ]
}
